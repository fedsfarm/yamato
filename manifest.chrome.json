{
  "manifest_version": 3,
  "name": "Yamato",
  "version": "2.0.0",
  "description": "Prevents you from being unmotivated",
  "permissions": [
    "tabs",
    "storage",
    "scripting",
    "offscreen",
    "webRequest",
    "webNavigation"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "vergil.png"
  },
  "commands": {
    "execute-run": {
      "suggested_key": {
        "default": "Ctrl+Shift+U"
      },
      "description": "Slice the current tab"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "vergil.png",
        "public/*",
        "pages/*"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "vergil.png",
    "32": "vergil.png",
    "48": "vergil.png",
    "128": "vergil.png"
  }
}
