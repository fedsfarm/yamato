{
  "manifest_version": 3,
  "name": "Yamato",
  "version": "2.0.0",
  "description": "Prevents you from being unmotivated",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Yamato"
  },
  "permissions": [
    "tabs",
    "storage",
    "scripting",
    "webRequest",
    "webRequestBlocking"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["run.js"],
      "run_at": "document_start"
    }
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "commands": {
    "execute-run": {
      "suggested_key": {
        "default": "Ctrl+Shift+U"
      },
      "description": "Slice the current tab"
    }
  },
  "web_accessible_resources": [
    {
      "resources": [
        "vergil.png",
        "public/*",
        "pages/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "icons": {
    "48": "vergil.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'sha256-WFiTe1ugrq+I+wTa1Kve4fwMWwJrc6bN2OOKr6uqxnU=' 'sha256-sERmrpxP+y4GKibh7W2+Wvnu+4hK84NX/0MJSLxkvho=' 'sha256-jqxtvDkBbRAl9Hpqv68WdNOieepg8tJSYu1xIy7zT34=' 'sha256-zL2UZaw4HjfCCigPBFeMknlz2nCwU55GB1eAFhRGxD8=' 'sha256-pL75uq2ZqjOUlOCnIqLgaGu3vcVrFFEuebvOWH+YG+0='; object-src 'self';"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "root@zeroarch.org",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
